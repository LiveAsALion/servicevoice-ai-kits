# ── PHX Pool Pro — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local dev, or set these as Docker env vars.
# NEVER commit .env.local or any file with real keys to git.

# Resend API key — get yours at https://resend.com (free tier: 100 emails/day)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where lead notifications are sent (your working email)
NOTIFY_EMAIL=Alex.Rivera.PPL@gmail.com

# The "From" address in outbound emails — must match a verified Resend domain
# Once you verify phxpoolpro.com in Resend, use: PHX Pool Pro <alex@phxpoolpro.com>
FROM_EMAIL=PHX Pool Pro <noreply@phxpoolpro.com>
