{
  "name": "SVAI - Founder Intelligence Log",
  "flow": [
    {
      "id": 1,
      "module": "gateway:CustomWebHook",
      "version": 1,
      "parameters": {
        "hook": null,
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": { "x": 0, "y": 0 },
        "restore": {
          "parameters": {
            "hook": {
              "label": "SVAI Founder Intelligence Webhook",
              "data": { "editable": true }
            }
          }
        }
      }
    },
    {
      "id": 2,
      "module": "builtin:BasicRouter",
      "version": 1,
      "parameters": {},
      "mapper": {},
      "metadata": {
        "designer": { "x": 300, "y": 0 }
      },
      "routes": [
        {
          "flow": [
            {
              "id": 3,
              "module": "google-sheets:addRow",
              "version": 2,
              "parameters": {
                "__IMTCONN__": null,
                "spreadsheetId": "REPLACE_WITH_YOUR_SPREADSHEET_ID",
                "sheetId": "Founder Intelligence Log",
                "includesHeaders": true,
                "valueRenderOption": "FORMATTED_VALUE",
                "insertDataOption": "INSERT_ROWS",
                "majorDimension": "ROWS"
              },
              "mapper": {
                "Timestamp": "{{formatDate(now; \"MM/DD/YYYY HH:mm\"; \"America/Phoenix\")}}",
                "Event Type": "lead",
                "Buyer ID": "n/a",
                "Niche": "{{1.niche}}",
                "Channel": "{{1.channel}}",
                "Language": "{{1.language}}",
                "Urgency": "{{1.urgency}}",
                "Revenue": "0",
                "Notes": "Caller: {{1.caller_name}} | Issue: {{1.issue_description}} | Address: {{1.address}}",
                "Status": "new"
              },
              "metadata": {
                "designer": { "x": 600, "y": -200 }
              }
            }
          ],
          "filter": {
            "name": "Inbound Lead",
            "conditions": [
              [
                {
                  "a": "{{1.event_type}}",
                  "b": "lead",
                  "o": "text:equal"
                }
              ]
            ]
          }
        },
        {
          "flow": [
            {
              "id": 4,
              "module": "google-sheets:addRow",
              "version": 2,
              "parameters": {
                "__IMTCONN__": null,
                "spreadsheetId": "REPLACE_WITH_YOUR_SPREADSHEET_ID",
                "sheetId": "Founder Intelligence Log",
                "includesHeaders": true,
                "valueRenderOption": "FORMATTED_VALUE",
                "insertDataOption": "INSERT_ROWS",
                "majorDimension": "ROWS"
              },
              "mapper": {
                "Timestamp": "{{formatDate(now; \"MM/DD/YYYY HH:mm\"; \"America/Phoenix\")}}",
                "Event Type": "purchase",
                "Buyer ID": "{{sha256(1.customer_email)}}",
                "Niche": "{{1.niche}}",
                "Channel": "direct",
                "Language": "{{1.language}}",
                "Urgency": "n/a",
                "Revenue": "{{1.amount}}",
                "Notes": "Product: {{1.product_name}} | Order: {{1.order_id}}",
                "Status": "active"
              },
              "metadata": {
                "designer": { "x": 600, "y": -50 }
              }
            }
          ],
          "filter": {
            "name": "Purchase",
            "conditions": [
              [
                {
                  "a": "{{1.event_type}}",
                  "b": "purchase",
                  "o": "text:equal"
                }
              ]
            ]
          }
        },
        {
          "flow": [
            {
              "id": 5,
              "module": "google-sheets:addRow",
