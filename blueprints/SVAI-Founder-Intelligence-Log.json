    }
  ],
  "metadata": {
    "instant": true,
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "slots": null,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    },
    "zone": "us2.make.com",
    "notes": [
      {
        "content": "SETUP REQUIRED:\n1. Connect Google Sheets account\n2. Replace REPLACE_WITH_YOUR_SPREADSHEET_ID with your Google Sheets ID\n3. Ensure your sheet has a tab named exactly: Founder Intelligence Log\n   Columns: Timestamp | Event Type | Buyer ID | Niche | Channel | Language | Urgency | Revenue | Notes | Status\n\nEVENT TYPES HANDLED (route this webhook from other scenarios):\n  - lead: inbound call captured by Retell AI\n  - purchase: Lemon Squeezy order.created webhook\n  - refund: Lemon Squeezy order.refunded webhook\n  - subscription_start: Lemon Squeezy subscription.created webhook\n  - subscription_cancel: Lemon Squeezy subscription.cancelled webhook\n  - survey_response: Tally webhook\n\nWEBHOOK PAYLOAD SCHEMA:\n{\n  \"event_type\": \"lead|purchase|refund|subscription_start|subscription_cancel|survey_response\",\n  \"caller_name\": \"string (leads only)\",\n  \"issue_description\": \"string (leads only)\",\n  \"address\": \"string (leads only)\",\n  \"callback_number\": \"string (leads only)\",\n  \"customer_email\": \"string (purchases/refunds/subscriptions)\",\n  \"order_id\": \"string (purchases/refunds)\",\n  \"product_name\": \"string (purchases/subscriptions)\",\n  \"amount\": \"number\",\n  \"niche\": \"HVAC|Plumbing|Electrical|Landscaping|Pool|Unknown\",\n  \"channel\": \"meta_ad|organic|direct|unknown\",\n  \"language\": \"english|spanish\",\n  \"urgency\": \"emergency|standard|estimate|n/a\",\n  \"reason\": \"string (refunds/cancellations only)\",\n  \"notes\": \"string (survey responses)\"\n}\n\nNOTE: Buyer IDs are SHA-256 hashes of email addresses — never raw PII is stored."
      }
    ]
  }
}
